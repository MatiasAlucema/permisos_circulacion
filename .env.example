# Proveedor de LLM para /predict/explain
# Opciones: "gemini" (default) o "anthropic"
LLM_PROVIDER=gemini

# API Key de Google Gemini (requerida si LLM_PROVIDER=gemini)
# Obtener en: https://aistudio.google.com/apikey
GEMINI_API_KEY=...

# API Key de Anthropic (requerida si LLM_PROVIDER=anthropic)
# Obtener en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...
